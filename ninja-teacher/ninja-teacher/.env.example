# ── Ninja-Teacher backend environment ────────────────────────────────────────
PORT=3000

# DATABASE — two supported modes (config/database.js):
#  • SQLite (zero setup, runs immediately):
DB_DIALECT=sqlite
SQLITE_PATH=./ninja_teacher.sqlite
#  • MySQL (production target) — set DB_DIALECT=mysql and fill these:
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=school_jobs
# DB_USER=root
# DB_PASSWORD=

# AUTH — CHANGE THESE SECRETS before any real deployment
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

ADMIN_SECRET=change_me_admin_secret
ADMIN_DEFAULT_EMAIL=admin@ninjateacher.com
ADMIN_DEFAULT_PASSWORD=ChangeMe@1234
ADMIN_DEFAULT_NAME=Super Admin
ADMIN_JWT_EXPIRES_IN=8h

CLIENT_URL=http://localhost:5173

# AI microservice (FastAPI, ai_model/) — optional; features degrade to 503 if down
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=4000
AI_RETRIES=1
# AI_SERVICE_KEY=        # leave empty unless the AI service enforces a key
